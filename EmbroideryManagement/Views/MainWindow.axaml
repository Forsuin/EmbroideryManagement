<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EmbroideryManagement.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="450"
        x:Class="EmbroideryManagement.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="EmbroideryManagement"
        Width="1280" Height="820"
        MinWidth="1000" MinHeight="620"
        Background="#f4f3ef"
        Foreground="#26281f">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Panel>
        <Grid RowDefinitions="Auto,*" ShowGridLines="True">
            <Border
                Grid.Row="0"
                Background="#fdfdfb"
                BorderBrush="#e3e1d6"
                BorderThickness="0,0,0,1"
                Padding="26, 15">
                <Grid ColumnDefinitions="Auto, Auto, *, Auto, Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10" Fill="#c9971f" />
                        <TextBlock Text="Stitchbox" FontWeight="SemiBold" FontSize="18" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20" Margin="26,0,0,0"
                                VerticalAlignment="Center">
                        <!-- <Button Classes="tab" Classes.active="{Binding }" Content="All patterns" -->
                        <!--         Command="{Binding SelectTabCommand}" CommandParameter="Patterns" /> -->
                        <!-- <Button Classes="navtab" Content="Collections" -->
                        <!--         Command="{Binding SelectTabCommand}" CommandParameter="Collections" /> -->

                        <TabStrip SelectedIndex="{Binding SelectedTabIndex}">
                            <TabStripItem>Patterns</TabStripItem>
                            <TabStripItem>Collections</TabStripItem>
                        </TabStrip>

                    </StackPanel>

                    <TextBox
                        Grid.Column="3"
                        Classes="search"
                        Width="220"
                        FontSize="13"
                        VerticalAlignment="Center"
                        Watermark="{Binding SearchWatermark}"
                        Text="{Binding SearchQuery}"
                        CornerRadius="8"
                        Padding="6"
                        Background="#F4F3EF"
                        BorderBrush="#DCDACD">
                        <TextBox.InnerLeftContent>
                            <PathIcon Width="14" Height="14" Margin="10,0,4,0"
                                      Foreground="#9a9a8f"
                                      Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" />
                        </TextBox.InnerLeftContent>
                    </TextBox>

                    <Button Grid.Column="4"
                            Classes="accent"
                            Margin="14, 0, 0, 0"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="+" FontSize="13" FontWeight="Bold" />
                            <TextBlock Text="Add pattern" FontSize="13" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" />
        </Grid>
    </Panel>


    <Window.Styles>
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="#c9971f" />
            <Setter Property="Foreground" Value="#ffffff" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16,9" />
        </Style>
        <Style Selector="Button.accent /template/ ContentPresenter">
            <Setter Property="Background" Value="#c9971f" />
            <Setter Property="Foreground" Value="#ffffff" />
        </Style>
        <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#b5871c" />
            <Setter Property="Foreground" Value="#ffffff" />
        </Style>
        <Style Selector="Button.accent:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#a87916" />
            <Setter Property="Foreground" Value="#ffffff" />
        </Style>

        <!-- the strip container: strip its chrome so it blends into the header -->
        <Style Selector="TabStrip">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <!-- base tab: quiet text link; underline handled by the theme's PART_SelectedPipe -->
        <Style Selector="TabStripItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="0,0,0,2" />
            <Setter Property="Margin" Value="0,0,20,0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="#85857a" />
            <Setter Property="Cursor" Value="Hand" />
            <!-- fade the text colour between tabs -->
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.18" />
                </Transitions>
            </Setter>
        </Style>

        <!-- gap between the tab text and the underline pipe: push the content up off the bottom,
             where PART_SelectedPipe is bottom-aligned -->
        <Style Selector="TabStripItem /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <!-- hover on an unselected tab: no underline, just darken the text.
             Foreground is set on the ContentPresenter (not the item) to beat Fluent's direct
             pointerover colour, which otherwise wins over an inherited value and turns text black. -->
        <Style Selector="TabStripItem:pointerover:not(:selected)">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TabStripItem:pointerover:not(:selected) /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#55564c" />
        </Style>

        <!-- SELECTED: gold text + recolour the theme's built-in underline pipe to gold -->
        <Style Selector="TabStripItem:selected">
            <Setter Property="Foreground" Value="#a8741a" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TabStripItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TabStripItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="Background" Value="#c9971f" />
        </Style>

        <!-- keep gold when hovering the already-selected tab (override at ContentPresenter level
             so Fluent's direct pointerover colour can't turn it black) -->
        <Style Selector="TabStripItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="#a8741a" />
        </Style>
        <Style Selector="TabStripItem:selected:pointerover /template/ Border#PART_SelectedPipe">
            <Setter Property="Background" Value="#c9971f" />
        </Style>
    </Window.Styles>
</Window>